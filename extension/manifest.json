{
  "manifest_version": 3,
  "name": "WhatsApp Web AI Copilot",
  "version": "1.0.0",
  "description": "AI-powered assistant for WhatsApp Web",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background/aiWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["src/content/domReader.js"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*"
  ]
}
